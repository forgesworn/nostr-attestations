graph TD
    subgraph SUBJECT["Subject"]
        S1["Publish assertion\n(any Nostr kind)"]
    end

    subgraph RELAY["Relay"]
        R1["Stores event\nID = abc123"]
    end

    subgraph ATTESTOR["Attestor"]
        A1["Fetch &amp; verify\nassertion event"]
        A2["Publish kind 31000\ne: abc123 · assertion"]
    end

    subgraph VERIFIER["Verifier"]
        V1["Query #e = abc123"]
        V2["Receive attestation(s)"]
        V3["Weight by WoT\ntrust score"]
    end

    S1 -->|"publish"| R1
    R1 -->|"fetch"| A1
    A1 --> A2
    A2 -->|"publish"| R1
    V1 -->|"query"| R1
    R1 -->|"return"| V2
    V2 --> V3

