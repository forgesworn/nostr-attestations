graph TD
    subgraph LIFECYCLE["Attestation Lifecycle"]
        PUB(["Publish"])
        PUB --> ACT

        ACT["Active\nlatest version wins"]
        ACT -->|"re-publish same d-tag"| ACT
        ACT -->|"add status: revoked"| REV
        ACT -->|"NIP-40 expiration passes"| EXP

        REV["Revoked\nsupersedes expiration"]
        EXP["Expired"]
    end

    style LIFECYCLE fill:#0d1117,stroke:#8b5cf6,color:#eee,stroke-width:2px
    style PUB fill:#1b3d2d,stroke:#16c79a,color:#eee
    style ACT fill:#1b3d2d,stroke:#16c79a,color:#eee,stroke-width:2px
    style REV fill:#3d1b1b,stroke:#ef4444,color:#eee,stroke-width:2px
    style EXP fill:#2d2d1b,stroke:#f59e0b,color:#eee,stroke-width:2px
